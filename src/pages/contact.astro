---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="联系" description="有想法、合作或交流，欢迎通过以下方式找到我。">

  <!-- Hero 标题 -->
  <div class="contact-hero container">
    <h1 class="hero-title">
      一起做点<br />
      <em>有意思的事情。</em>
    </h1>
    <p class="hero-sub">专注于 AI Agent 探索与内容创作。如果你对 AI 工具、写作工作流或相关合作感兴趣，欢迎联系。</p>
  </div>

  <!-- 联系卡片 2×2 -->
  <div class="cards-wrap container">
    <a href="mailto:3258580458@qq.com" class="contact-card">
      <div class="card-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/>
        </svg>
      </div>
      <p class="card-label">邮箱</p>
      <p class="card-value">3258580458@qq.com</p>
    </a>

    <a href="https://x.com/zzy17813100102" target="_blank" rel="noopener" class="contact-card">
      <div class="card-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </div>
      <p class="card-label">X / Twitter</p>
      <p class="card-value">@zzy17813100102</p>
    </a>

    <a href="https://github.com/zzylanmengqingchuan" target="_blank" rel="noopener" class="contact-card">
      <div class="card-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
      </div>
      <p class="card-label">GitHub</p>
      <p class="card-value">zzylanmengqingchuan</p>
    </a>

    <a href="https://wx.zsxq.com/group/28882558852421" target="_blank" rel="noopener" class="contact-card">
      <div class="card-icon">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
          <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
      </div>
      <p class="card-label">知识星球</p>
      <p class="card-value">象牙塔研习社</p>
    </a>
  </div>

  <!-- 氛围图 -->
  <div class="atmos-wrap container">
    <div class="atmos-img">
      <img src="/covers/25.png" alt="atmosphere" loading="lazy" />
      <span class="atmos-caption">持续学习 · 持续记录 · 持续成长</span>
    </div>
  </div>

  <!-- 引言 -->
  <div class="quote-wrap container">
    <blockquote class="quote">
      "工具从来不是终点，而是起点。真正重要的是那些工具背后的问题、判断和持续的好奇心。"
    </blockquote>
  </div>

  <!-- CTA -->
  <div class="cta-wrap container">
    <a href="mailto:3258580458@qq.com" class="cta-btn">
      发送邮件联系我
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
    <p class="cta-note">通常在 24 小时内回复</p>
  </div>

</BaseLayout>

<style>
  /* ── Hero ── */
  .contact-hero {
    padding: 80px 0 56px;
    max-width: 800px;
  }

  .hero-title {
    margin: 0 0 20px;
    color: var(--color-neutral-strong);
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -1.5px;
  }

  .hero-title em {
    font-style: italic;
    background: linear-gradient(90deg, #6475ff, #a78bfa, #60a5fa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    margin: 0;
    color: var(--color-neutral-muted);
    font-size: 17px;
    line-height: 1.75;
    max-width: 540px;
  }

  /* ── Cards ── */
  .cards-wrap {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    padding-bottom: 40px;
    max-width: 800px;
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 28px 28px 24px;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: 16px;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .contact-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(100,117,255,0.1);
  }

  .card-icon {
    color: var(--color-primary);
    opacity: 0.8;
  }

  .card-label {
    margin: 0;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-neutral-muted);
  }

  .card-value {
    margin: 0;
    font-size: 18px;
    font-weight: 500;
    color: var(--color-neutral-strong);
    line-height: 1.3;
    transition: color 0.15s;
  }

  .contact-card:hover .card-value {
    color: var(--color-primary);
  }

  /* ── Atmosphere image ── */
  .atmos-wrap {
    max-width: 800px;
    padding-bottom: 40px;
  }

  .atmos-img {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
  }

  .atmos-img img {
    width: 100%;
    aspect-ratio: 21/9;
    object-fit: cover;
    display: block;
    filter: brightness(0.85);
  }

  .atmos-caption {
    position: absolute;
    bottom: 16px;
    left: 20px;
    font-size: 13px;
    font-style: italic;
    color: rgba(255,255,255,0.75);
    letter-spacing: 0.04em;
  }

  /* ── Quote ── */
  .quote-wrap {
    max-width: 800px;
    padding-bottom: 48px;
  }

  .quote {
    margin: 0;
    padding: 20px 0 20px 28px;
    border-left: 3px solid var(--color-primary);
    color: var(--color-neutral-muted);
    font-size: 17px;
    font-style: italic;
    line-height: 1.8;
  }

  /* ── CTA ── */
  .cta-wrap {
    max-width: 800px;
    padding-bottom: 96px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background: var(--color-primary);
    color: white;
    border-radius: 99px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
  }

  .cta-btn:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(100,117,255,0.3);
  }

  .cta-note {
    margin: 0;
    font-size: 13px;
    color: var(--color-neutral-muted);
  }

  @media (max-width: 600px) {
    .cards-wrap { grid-template-columns: 1fr; }
    .hero-title { letter-spacing: -0.5px; }
    .atmos-img img { aspect-ratio: 16/9; }
  }
</style>
