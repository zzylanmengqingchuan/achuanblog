---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const articles = (await getCollection("articles"))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);

const works = (await getCollection("works"))
  .filter((w) => w.data.featured)
  .slice(0, 4);
---

<BaseLayout>
  <div class="home">

    <!-- Avatar -->
    <div class="avatar-wrap">
      <img src="/logo.jpg" alt="阑梦清川" class="avatar" />
    </div>

    <!-- Profile Card -->
    <div class="profile-card">
      <div class="profile-top">
        <div class="profile-text">
          <p class="greeting">Hi, 我是</p>
          <h1 class="name">阑梦清川</h1>
          <p class="role">AI Agent 深度用户 · 内容创作者</p>
        </div>
      </div>

      <!-- Quick nav tags -->
      <div class="quick-nav">
        <a href="/about" class="tag">了解我</a>
        <a href="/works" class="tag">查看作品</a>
        <a href="/articles" class="tag">读文章</a>
        <a href="/growth" class="tag">成长路径</a>
        <a href="/contact" class="tag">联系我</a>
      </div>

      <!-- Social links -->
      <div class="social-row">
        <a href="https://github.com/zzylanmengqingchuan" target="_blank" rel="noopener" class="social-link" title="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
        </a>
        <a href="https://x.com/zzy17813100102" target="_blank" rel="noopener" class="social-link" title="X / Twitter">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a href="https://wx.zsxq.com/group/28882558852421" target="_blank" rel="noopener" class="social-link" title="知识星球">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2a10 10 0 100 20A10 10 0 0012 2zm0 18a8 8 0 110-16 8 8 0 010 16zm-1-5h2v2h-2zm0-8h2v6h-2z"/></svg>
        </a>
        <a href="mailto:3258580458@qq.com" class="social-link" title="邮箱">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 01-2.06 0L2 7"/></svg>
        </a>
      </div>
    </div>

    <!-- Info cards -->
    <div class="cards-grid">

      <!-- Recent Articles -->
      <div class="info-card">
        <div class="card-header">
          <span class="card-label">最新文章</span>
          <a href="/articles" class="card-more">全部 →</a>
        </div>
        <ul class="article-list">
          {articles.map((a) => (
            <li>
              <a href={`/articles/${a.id}`} class="article-item">
                <span class="article-title">{a.data.title}</span>
                <span class="article-date">{a.data.date.toLocaleDateString("zh-CN", { month: "2-digit", day: "2-digit" })}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Works -->
      <div class="info-card">
        <div class="card-header">
          <span class="card-label">作品精选</span>
          <a href="/works" class="card-more">全部 →</a>
        </div>
        <ul class="works-list">
          {works.map((w) => (
            <li>
              <div class="work-item">
                <span class="work-title">{w.data.title}</span>
                <p class="work-desc">{w.data.description}</p>
                <div class="work-tags">
                  {w.data.tags?.slice(0, 3).map((t: string) => (
                    <span class="work-tag">{t}</span>
                  ))}
                </div>
              </div>
            </li>
          ))}
        </ul>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .home {
    width: min(100% - 40px, var(--layout-home-max));
    margin-inline: auto;
    padding: 56px 0 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  /* Avatar */
  .avatar-wrap {
    margin-bottom: 20px;
  }

  .avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-border-strong);
  }

  /* Profile Card */
  .profile-card {
    width: 100%;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    padding: 28px 28px 24px;
    box-shadow: var(--shadow-card);
  }

  .greeting {
    margin: 0 0 4px;
    color: var(--color-neutral-muted);
    font-size: 15px;
  }

  .name {
    margin: 0 0 8px;
    color: var(--color-primary);
    font-size: 32px;
    font-weight: 600;
    letter-spacing: -0.5px;
  }

  .role {
    margin: 0;
    color: var(--color-neutral-muted);
    font-size: 15px;
  }

  .quick-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }

  .tag {
    border: 1px solid var(--color-border-strong);
    border-radius: 99px;
    padding: 5px 14px;
    color: var(--color-neutral-muted);
    font-size: 13px;
    text-decoration: none;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }

  .tag:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: var(--color-primary-soft);
  }

  .social-row {
    display: flex;
    gap: 4px;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid var(--color-border-subtle);
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    color: var(--color-neutral-muted);
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }

  .social-link:hover {
    color: var(--color-neutral-strong);
    background: var(--color-surface-muted);
  }

  /* Cards grid */
  .cards-grid {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 16px;
  }

  .info-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    padding: 20px;
    box-shadow: var(--shadow-card);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .card-label {
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-neutral-muted);
  }

  .card-more {
    font-size: 12px;
    color: var(--color-primary);
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.15s;
  }

  .card-more:hover {
    opacity: 1;
  }

  /* Article list */
  .article-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .article-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
    padding: 7px 0;
    border-bottom: 1px solid var(--color-border-subtle);
    text-decoration: none;
    transition: color 0.15s;
  }

  .article-list li:last-child .article-item {
    border-bottom: none;
  }

  .article-title {
    color: var(--color-neutral);
    font-size: 13px;
    line-height: 1.5;
    flex: 1;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
  }

  .article-item:hover .article-title {
    color: var(--color-primary);
  }

  .article-date {
    color: var(--color-neutral-muted);
    font-size: 12px;
    flex-shrink: 0;
  }

  /* Works list */
  .works-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .work-item {
    padding-bottom: 12px;
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .works-list li:last-child .work-item {
    border-bottom: none;
    padding-bottom: 0;
  }

  .work-title {
    display: block;
    color: var(--color-neutral);
    font-size: 13px;
    font-weight: 500;
    line-height: 1.4;
    margin-bottom: 4px;
  }

  .work-desc {
    margin: 0 0 6px;
    color: var(--color-neutral-muted);
    font-size: 12px;
    line-height: 1.5;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .work-tag {
    border: 1px solid var(--color-border-subtle);
    border-radius: 4px;
    padding: 1px 6px;
    color: var(--color-neutral-muted);
    font-size: 11px;
  }

  @media (max-width: 560px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }

    .name {
      font-size: 26px;
    }
  }
</style>
