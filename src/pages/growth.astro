---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const items = (await getCollection("growth")).sort((a, b) => a.data.order - b.data.order);

const themeColors: Record<string, string> = {
  "写作": "#6475ff",
  "AI":   "#a78bfa",
  "学习": "#34d399",
  "创作": "#f59e0b",
  "其他": "#6b7280",
};
---

<BaseLayout title="成长路径" description="一些真正改变我的节点：写作、AI、工具，以及不断看到正反馈的过程。">

  <div class="page-head container">
    <p class="eyebrow">Growth</p>
    <h1>成长路径</h1>
    <p class="sub">一些真正改变我的节点：写作、AI、工具，以及不断看到正反馈的过程。</p>
  </div>

  <div class="timeline-wrap container">

    <!-- 中轴线 -->
    <div class="timeline-line" aria-hidden="true"></div>

    {items.map((item, i) => {
      const isEven = i % 2 === 1;
      const color = themeColors[item.data.theme] ?? themeColors["其他"];
      return (
        <div class:list={["timeline-item", { even: isEven }]}>

          <!-- 文字侧 -->
          <div class="item-text">
            <span class="item-period">{item.data.period}</span>
            <h2 class="item-title">{item.data.title}</h2>
            <p class="item-summary">{item.data.summary}</p>
            <span class="item-theme" style={`color:${color};border-color:${color}30;background:${color}10`}>
              {item.data.theme}
            </span>
          </div>

          <!-- 时间轴节点 -->
          <div class="item-dot-wrap">
            <div class="item-dot" style={`background:${color};box-shadow:0 0 0 4px ${color}20`}></div>
          </div>

          <!-- 图片侧 -->
          <div class="item-image">
            {item.data.cover
              ? <img src={item.data.cover} alt={item.data.title} loading="lazy" />
              : <div class="img-placeholder" style={`background:linear-gradient(135deg,${color}18,${color}06)`}>
                  <span style={`color:${color};opacity:0.4`}>{item.data.theme}</span>
                </div>
            }
          </div>

        </div>
      );
    })}

  </div>

</BaseLayout>

<style>
  .page-head {
    padding: 64px 0 56px;
    text-align: center;
  }

  .eyebrow {
    margin: 0 0 12px;
    color: var(--color-primary);
    font-size: 13px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 14px;
    color: var(--color-neutral-strong);
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 700;
    letter-spacing: -1px;
  }

  .sub {
    margin: 0 auto;
    color: var(--color-neutral-muted);
    font-size: 16px;
    line-height: 1.7;
    max-width: 480px;
  }

  /* ── Timeline wrapper ── */
  .timeline-wrap {
    position: relative;
    max-width: 900px;
    padding-bottom: 96px;
  }

  /* 中轴线 */
  .timeline-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--color-border-strong);
    transform: translateX(-50%);
  }

  /* ── Each item ── */
  .timeline-item {
    display: grid;
    grid-template-columns: 1fr 48px 1fr;
    align-items: center;
    gap: 0;
    margin-bottom: 80px;
    position: relative;
  }

  /* even: flip text and image */
  .timeline-item.even .item-text  { order: 3; text-align: left;  }
  .timeline-item.even .item-dot-wrap { order: 2; }
  .timeline-item.even .item-image { order: 1; }

  /* ── Text side ── */
  .item-text {
    padding: 0 32px 0 0;
    text-align: right;
    animation: fadeInLeft 0.6s cubic-bezier(0.16,1,0.3,1) both;
  }

  .timeline-item.even .item-text {
    padding: 0 0 0 32px;
    animation: fadeInRight 0.6s cubic-bezier(0.16,1,0.3,1) both;
  }

  @keyframes fadeInLeft {
    from { opacity: 0; transform: translateX(-20px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes fadeInRight {
    from { opacity: 0; transform: translateX(20px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .item-period {
    display: block;
    font-size: 13px;
    color: var(--color-neutral-muted);
    margin-bottom: 10px;
    letter-spacing: 0.04em;
  }

  .item-title {
    margin: 0 0 12px;
    color: var(--color-neutral-strong);
    font-size: clamp(20px, 2.5vw, 26px);
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.3px;
  }

  .item-summary {
    margin: 0 0 14px;
    color: var(--color-neutral-muted);
    font-size: 14px;
    line-height: 1.75;
    font-style: italic;
  }

  .item-theme {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid;
    border-radius: 99px;
    padding: 3px 10px;
  }

  /* ── Dot ── */
  .item-dot-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .item-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    transition: transform 0.2s;
  }

  .timeline-item:hover .item-dot {
    transform: scale(1.5);
  }

  /* ── Image side ── */
  .item-image {
    padding: 0 0 0 32px;
    animation: fadeInRight 0.6s cubic-bezier(0.16,1,0.3,1) both;
  }

  .timeline-item.even .item-image {
    padding: 0 32px 0 0;
    animation: fadeInLeft 0.6s cubic-bezier(0.16,1,0.3,1) both;
  }

  .item-image img {
    width: 100%;
    aspect-ratio: 4/3;
    object-fit: cover;
    border-radius: 16px;
    display: block;
    border: 1px solid var(--color-border-subtle);
    transition: transform 0.3s ease, box-shadow 0.3s;
  }

  .timeline-item:hover .item-image img {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.15);
  }

  .img-placeholder {
    width: 100%;
    aspect-ratio: 4/3;
    border-radius: 16px;
    border: 1px solid var(--color-border-subtle);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
  }

  /* ── Responsive ── */
  @media (max-width: 700px) {
    .timeline-line { left: 20px; }

    .timeline-item,
    .timeline-item.even {
      grid-template-columns: 40px 1fr;
      grid-template-rows: auto auto;
      margin-bottom: 48px;
    }

    .timeline-item .item-dot-wrap,
    .timeline-item.even .item-dot-wrap { order: 1; align-self: start; padding-top: 4px; }

    .timeline-item .item-text,
    .timeline-item.even .item-text {
      order: 2; text-align: left;
      padding: 0 0 16px 0;
    }

    .timeline-item .item-image,
    .timeline-item.even .item-image {
      order: 3;
      grid-column: 2;
      padding: 0;
    }
  }
</style>
