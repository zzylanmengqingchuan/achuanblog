---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate } from "../../utils/date";

const allArticles = (await getCollection("articles"))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const PAGE_SIZE = 9;
const totalPages = Math.ceil(allArticles.length / PAGE_SIZE);
---

<BaseLayout title="文章" description="关于 AI Agent、工具体验、读书笔记和个人成长的长期记录。">

  <div class="page-head container">
    <h1>精选文章</h1>
    <p class="sub">关于 AI、工具、学习与成长的思考与记录。</p>
  </div>

  <div class="articles-grid container" id="articles-grid">
    {allArticles.slice(0, PAGE_SIZE).map((a) => (
      <a href={`/articles/${a.slug}`} class="art-card">
        <div class="art-cover">
          {a.data.cover
            ? <img src={a.data.cover} alt={a.data.title} loading="lazy" />
            : <div class="art-placeholder"><span>{a.data.category}</span></div>
          }
        </div>
        <div class="art-body">
          <div class="art-tags">
            {a.data.tags.slice(0, 2).map((t) => (
              <span class="art-tag">{t}</span>
            ))}
          </div>
          <h2 class="art-title">{a.data.title}</h2>
          <p class="art-desc">{a.data.description}</p>
          <div class="art-footer">
            <span class="art-date">{formatDate(a.data.date)}</span>
            <span class="art-read">阅读全文</span>
          </div>
        </div>
      </a>
    ))}
  </div>

  {totalPages > 1 && (
    <div class="pager container">
      <button id="prev-btn" class="pager-arrow" disabled aria-label="上一页">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <div class="pager-nums" id="pager-nums">
        {Array.from({ length: totalPages }, (_, i) => (
          <button class={`pager-num${i === 0 ? " active" : ""}`} data-page={i + 1}>{i + 1}</button>
        ))}
      </div>
      <button id="next-btn" class="pager-arrow" disabled={totalPages <= 1} aria-label="下一页">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  )}

</BaseLayout>

<script define:vars={{ articlesData: allArticles.map(a => ({
  slug: a.slug,
  title: a.data.title,
  description: a.data.description,
  date: a.data.date.toISOString(),
  category: a.data.category,
  tags: a.data.tags,
  cover: a.data.cover ?? null,
})), PAGE_SIZE, totalPages }}>

  let currentPage = 1;

  function fmt(iso) {
    const d = new Date(iso);
    return `${d.getFullYear()}年${String(d.getMonth()+1).padStart(2,'0')}月${String(d.getDate()).padStart(2,'0')}日`;
  }

  function renderPage(page) {
    const grid = document.getElementById('articles-grid');
    if (!grid) return;
    const items = articlesData.slice((page - 1) * PAGE_SIZE, page * PAGE_SIZE);
    grid.innerHTML = items.map(a => `
      <a href="/articles/${a.slug}" class="art-card">
        <div class="art-cover">
          ${a.cover
            ? `<img src="${a.cover}" alt="${a.title.replace(/"/g,'&quot;')}" loading="lazy">`
            : `<div class="art-placeholder"><span>${a.category}</span></div>`}
        </div>
        <div class="art-body">
          <div class="art-tags">
            ${a.tags.slice(0,2).map(t=>`<span class="art-tag">${t}</span>`).join('')}
          </div>
          <h2 class="art-title">${a.title}</h2>
          <p class="art-desc">${a.description}</p>
          <div class="art-footer">
            <span class="art-date">${fmt(a.date)}</span>
            <span class="art-read">阅读全文</span>
          </div>
        </div>
      </a>
    `).join('');
    document.getElementById('articles-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function updatePager(page) {
    document.getElementById('prev-btn').disabled = page <= 1;
    document.getElementById('next-btn').disabled = page >= totalPages;
    document.querySelectorAll('.pager-num').forEach(b => {
      b.classList.toggle('active', Number(b.dataset.page) === page);
    });
  }

  function goTo(page) {
    if (page < 1 || page > totalPages) return;
    currentPage = page;
    if (page > 1) renderPage(page);
    updatePager(page);
  }

  document.getElementById('prev-btn')?.addEventListener('click', () => goTo(currentPage - 1));
  document.getElementById('next-btn')?.addEventListener('click', () => goTo(currentPage + 1));
  document.querySelectorAll('.pager-num').forEach(b =>
    b.addEventListener('click', () => goTo(Number(b.dataset.page)))
  );
</script>

<!-- is:global 确保动态注入的卡片也能获得样式 -->
<style is:global>
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding-bottom: 40px;
  }

  .art-card {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: 16px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.22s cubic-bezier(0.16,1,0.3,1), box-shadow 0.22s, border-color 0.22s;
  }

  .art-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-border-strong);
    box-shadow: 0 16px 40px rgba(0,0,0,0.12);
  }

  .art-cover {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--color-surface-muted);
    flex-shrink: 0;
  }

  .art-cover img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
    transition: transform 0.4s ease;
  }

  .art-card:hover .art-cover img { transform: scale(1.04); }

  .art-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, var(--color-surface-muted), var(--color-surface));
  }

  .art-placeholder span {
    font-size: 12px; color: var(--color-neutral-muted); opacity: 0.5;
  }

  .art-body {
    display: flex; flex-direction: column; flex: 1;
    padding: 18px 20px;
  }

  .art-tags {
    display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px;
  }

  .art-tag {
    border: 1px solid var(--color-border-strong);
    border-radius: 99px; padding: 2px 9px;
    font-size: 11px; color: var(--color-neutral-muted);
  }

  .art-title {
    margin: 0 0 8px;
    color: var(--color-neutral-strong);
    font-size: 15px; font-weight: 600; line-height: 1.45;
    transition: color 0.15s;
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
  }

  .art-card:hover .art-title { color: var(--color-primary); }

  .art-desc {
    margin: 0; flex: 1;
    color: var(--color-neutral-muted);
    font-size: 13px; line-height: 1.6;
    display: -webkit-box; -webkit-line-clamp: 2;
    -webkit-box-orient: vertical; overflow: hidden;
  }

  .art-footer {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 14px; padding-top: 12px;
    border-top: 1px solid var(--color-border-subtle);
  }

  .art-date { font-size: 12px; color: var(--color-neutral-muted); }

  .art-read {
    font-size: 12px; font-weight: 600;
    color: var(--color-neutral-strong); transition: color 0.15s;
  }

  .art-card:hover .art-read { color: var(--color-primary); }

  @media (max-width: 900px) {
    .articles-grid { grid-template-columns: repeat(2,1fr); gap: 18px; }
  }
  @media (max-width: 560px) {
    .articles-grid { grid-template-columns: 1fr; gap: 16px; }
  }

  /* ── Page head ── */
  .page-head { padding: 64px 0 40px; }

  .page-head h1 {
    margin: 0 0 10px;
    color: var(--color-neutral-strong);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700; letter-spacing: -0.5px;
  }

  .sub {
    margin: 0; color: var(--color-neutral-muted);
    font-size: 16px; line-height: 1.6; max-width: 480px;
  }

  /* ── Pagination ── */
  .pager {
    display: flex !important;
    flex-direction: row !important;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 8px 0 80px;
  }

  .pager-arrow {
    display: flex !important;
    align-items: center;
    justify-content: center;
    width: 34px; height: 34px;
    border: 1px solid var(--color-border-strong) !important;
    border-radius: 50% !important;
    background: var(--color-surface) !important;
    color: var(--color-neutral-muted);
    cursor: pointer;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
    padding: 0;
  }

  .pager-arrow:not(:disabled):hover {
    border-color: var(--color-primary) !important;
    color: var(--color-primary);
  }

  .pager-arrow:disabled { opacity: 0.3; cursor: not-allowed; }

  .pager-nums {
    display: flex !important;
    flex-direction: row !important;
    align-items: center;
    gap: 2px;
  }

  .pager-num {
    display: flex !important;
    align-items: center;
    justify-content: center;
    width: 34px; height: 34px;
    border: none !important;
    border-radius: 50% !important;
    background: transparent !important;
    color: var(--color-neutral-muted);
    font-size: 14px; cursor: pointer;
    transition: background 0.15s, color 0.15s;
    padding: 0;
  }

  .pager-num:hover:not(.active) {
    background: var(--color-surface-muted) !important;
    color: var(--color-neutral);
  }

  .pager-num.active {
    background: var(--color-primary) !important;
    color: white !important;
    font-weight: 600;
  }
</style>
